# ── GitLab ────────────────────────────────────────────────────────────────────
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# ── Transport ─────────────────────────────────────────────────────────────────
MODE=http
PORT=3000

# ── TLS (optional — enable HTTPS without nginx) ───────────────────────────────
# SSL_CERT_PATH=/etc/letsencrypt/live/example.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/example.com/privkey.pem

# ── Public URL (used in OAuth metadata, required when using HTTPS/custom port) ─
# SERVER_URL=https://example.com:3000

# ── Auth: OAuth 2.0 (recommended for Claude.ai web) ──────────────────────────
# Claude.ai → Settings → Connectors → OAuth Client ID / OAuth Client Secret
OAUTH_CLIENT_ID=my-gitlab-connector
OAUTH_CLIENT_SECRET=change-me-use-a-strong-random-value

# ── Auth: legacy Bearer token (fallback if OAuth not used) ───────────────────
# MCP_SECRET=change-me-use-a-strong-random-value
